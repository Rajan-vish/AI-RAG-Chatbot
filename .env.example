GOOGLE_API_KEY=<your-google-api-key>

# ============================================================================
# Embedding Configuration
# ============================================================================

# Embedding provider: "auto", "gemini", or "local"
# - auto: Gemini API with local fallback (DEFAULT)
# - gemini: Gemini API only (requires GOOGLE_API_KEY)
# - local: Local model only (nomic-embed-text-v1)
EMBEDDING_PROVIDER=auto

# Gemini embedding model (only used when provider is gemini or auto)
# Default: gemini-embedding-001
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Local embedding model path (only used when provider is local or auto fallback)
# Default: ./models/nomic-embed-text-v1
EMBEDDING_MODEL_PATH=./models/nomic-embed-text-v1

# NOTE: Embedding dimension is fixed at 768 and enforced by the system.
# All embedders must produce exactly 768 dimensions.

CHROMA_PERSIST_DIR=./chroma_data

# ============================================================================
# Query Configuration
# ============================================================================

# Number of chunks to retrieve for each query (default: 5)
# Higher values provide more context but may slow down responses
RETRIEVAL_K=10

# LLM temperature for answer generation (default: 0.3)
# Lower = more focused/factual, Higher = more creative
# Recommended: 0.1-0.4 for RAG applications
LLM_TEMPERATURE=0.3

# Duplicate detection threshold (default: 0.85)
# Chunks with similarity above this are considered duplicates and filtered
# Range: 0.0-1.0 (0.85 = 85% similar text is duplicate)
DUPLICATE_THRESHOLD=0.85

# ============================================================================
# Retrieval Mode Configuration
# ============================================================================

# Retrieval mode: "hybrid", "keyword", or "semantic"
# - hybrid: Combine semantic + keyword search with RRF fusion (DEFAULT)
# - keyword: BM25 keyword-only (falls back to semantic on failure)
# - semantic: Vector similarity only (original behavior)
RETRIEVAL_MODE=hybrid

# RRF constant for hybrid fusion (default: 60)
# Higher values give more weight to top-ranked results
# Standard value is 60, but can be tuned for your use case
RRF_K=60